VITE_BASE=/

# 打包后本地预览（pnpm preview）监听端口；服务器上用 Nginx/Caddy 转发时请与此或运维约定一致
VITE_PREVIEW_PORT=8082

# 接口地址
VITE_GLOB_API_URL=/

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
