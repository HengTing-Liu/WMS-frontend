# 端口号
VITE_PORT=5666

VITE_BASE=/

# 开发时 Vite 将 /api 代理到此后端（与 wms-center-web dev application.yml server.port 默认 8087 对齐）
VITE_DEV_PROXY_TARGET=http://localhost:8087

# 接口地址（相对路径，走本地代理转发到 VITE_DEV_PROXY_TARGET）
VITE_GLOB_API_URL=/

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭
VITE_NITRO_MOCK=false

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=true

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
